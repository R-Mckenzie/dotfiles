# Ross Mckenzie
# Terminal Aliases

# vim -> nvim
alias vim="nvim"
alias v="nvim"
alias vi="nvim"

# easy dotfile editing
alias vimrc="nvim ~/.config/nvim/init.vim"
alias i3rc="nvim ~/.i3/config"

# git
alias glog="git log --graph --pretty=format:'%cred%h%Creset -%C(yellow)%d%Creset %s%Cgreen(%cr) %C(bold blue)<%an>%Creset'"
